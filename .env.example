# ── Syslog destination (Cisco ASA, Firepower, Checkpoint, Fortinet, HTTPD, Zscaler, Infoblox) ──
SYSLOG_HOST=<your-xsiam-syslog-collector-ip>

# ── XSIAM HTTP Event Collector (all HTTP-transport modules) ───────────────────────────────────
HTTP_COLLECTOR_URL=https://api-<your-tenant>.xdr.us.paloaltonetworks.com/logs/v1/event

# ── Okta SSO ─────────────────────────────────────────────────────────────────────────────────
OKTA_COLLECTOR_URL=
OKTA_AUTH_TYPE=
OKTA_KEY=

# ── Windows Event Log ────────────────────────────────────────────────────────────────────────
# Leave WINDOWS_EVENTS_COLLECTOR_URL blank to use the global HTTP_COLLECTOR_URL above.
WINDOWS_EVENTS_COLLECTOR_URL=
WINDOWS_EVENTS_KEY=

# ── Proofpoint Email ─────────────────────────────────────────────────────────────────────────
PROOFPOINT_COLLECTOR_URL=
PROOFPOINT_AUTH_TYPE=
PROOFPOINT_KEY=

# ── Google Workspace collectors ────WORK IN PROGRESS──────────────────────────────────────────
GOOGLE_LOGIN_COLLECTOR_URL=
GOOGLE_AUTH_TYPE=
GOOGLE_LOGIN_KEY=
GOOGLE_ADMIN_KEY=
GOOGLE_DRIVE_KEY=
GOOGLE_USER_ACCOUNTS_KEY=
GOOGLE_TOKEN_KEY=

# ── AWS CloudTrail (S3 transport) ─────────────────────────────────────────────────────────────
s3_bucket_name=
aws_account_id=
aws_region=us-east-1
aws_access_key_id=
aws_secret_access_key=

# ── GCP Cloud Audit Logs (Pub/Sub transport) ──────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_PUBSUB_TOPIC=
# Option A: path to a service account JSON key file mounted into the container
# GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-key.json
# Option B: inline service account JSON (single line, no newlines)
GCP_SERVICE_ACCOUNT_KEY_JSON=
