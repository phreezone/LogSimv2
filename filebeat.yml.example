# ============================================================================
# XDR Collector (XDRC) profile for LogSim Windows Event Log module
# ============================================================================
#
# The XDR Collector is Palo Alto's custom Filebeat fork that ships with
# managed connectivity to XSIAM — no output/SSL/logging config needed.
# Push this YAML as a collector profile from the XSIAM console.
#
# Docs: https://docs-cortex.paloaltonetworks.com/r/Cortex-XDR/Cortex-XDR-3.x-Documentation/XDR-Collector-XDRC
#
# Each simulated host gets its own subdirectory under filebeat_output/:
#   filebeat_output/WKS001.examplecorp.local/security.json
#   filebeat_output/WKS002.examplecorp.local/security.json
#   filebeat_output/DC01.examplecorp.local/security.json
#
# Usage:
#   1. Set "transport": "filebeat" in config.json under windows_events_config
#   2. Start LogSim — it writes JSONL files into filebeat_output/
#   3. Create an XDRC profile in XSIAM with this YAML
#   4. Install XDRC on the LogSim host and assign this profile
#   5. Events flow to XSIAM → microsoft_windows_raw dataset
# ============================================================================

filebeat.inputs:

  - type: filestream
    id: logsim-windows-events
    enabled: true

    paths:
      - c:\LogSim\filebeat_output\*\security.json

    parsers:
      - ndjson:
          target: ""
          overwrite_keys: true
          add_error_key: true

    processors:
      - add_fields:
          fields:
            vendor: "microsoft"
            product: "windows"
      - dissect:
          tokenizer: '%{}\filebeat_output\%{host.name}\security.json'
          field: "log.file.path"
          target_prefix: ""
          ignore_failure: true

    file_identity.native: ~
    prospector.scanner:
      check_interval: 5s
